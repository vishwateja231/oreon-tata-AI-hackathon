# ==============================================================================
# OREON — Environment Configuration
# Copy to .env and fill in real values. Never commit .env to version control.
#
# Deployment target:  Oracle VM.Standard.E2.1.Micro (1 CPU / 1 GB RAM)
# Database:           Supabase Postgres (external)
# Cache:              Upstash Redis     (external)
# Frontend:           Vercel            (external)
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Oreon"
APP_VERSION="1.0.0"
DEBUG=false
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret-key

# ── Supabase PostgreSQL ───────────────────────────────────────────────────────
# Use the "Transaction" pooler URL (port 6543) for the app.
# Use the "Session"     pooler URL (port 5432) for alembic migrations.
#
# Supabase dashboard → Project Settings → Database → Connection string
# Replace <password> with your actual DB password (URL-encode @ as %40).
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Upstash Redis (TLS) ───────────────────────────────────────────────────────
# Upstash dashboard → Database → REST API → Connection → rediss:// URL
# Must use rediss:// (double-s) for TLS — plain redis:// will be rejected.
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Primary: "groq" (~2 s, free tier) | "openrouter" (~5-15 s)
LLM_PROVIDER=groq

# Groq — https://console.groq.com (free, fast)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — https://openrouter.ai/keys (fallback)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_FAST_MODEL=openai/gpt-4o-mini
OPENROUTER_REASONING_MODEL=openai/gpt-4o-mini
OPENROUTER_VOICE_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_VOICE_MAX_TOKENS=280
OPENROUTER_VOICE_TIMEOUT=30

# ── Vector Store (Qdrant — embedded) ─────────────────────────────────────────
# Leave BOTH blank to use the local embedded Qdrant stored in the backend_data
# Docker volume (/app/data/chroma/qdrant). No external service needed.
QDRANT_URL=
QDRANT_API_KEY=

# ── RAG Embeddings ────────────────────────────────────────────────────────────
# false = fast hash-vectors + BM25 (default, <300ms, no model download)
# true  = BGE-M3 semantic embeddings (~2 GB download — NOT suitable for 1 GB VM)
USE_BGE_EMBEDDINGS=false
HF_TOKEN=

# ── Voice / STT ───────────────────────────────────────────────────────────────
# https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Data paths ────────────────────────────────────────────────────────────────
# Inside the container — maps to the backend_data Docker volume
DATA_DIR=/app/data

# ==============================================================================
# OREON Production Environment Configuration
# ==============================================================================

# ── 1. Application Settings ───────────────────────────────────────────────────
APP_NAME="Oreon"
APP_VERSION="1.0.0"
DEBUG=false

# Generate a secure 32-character hex string for production (e.g. `openssl rand -hex 32`)
SECRET_KEY="replace-this-with-a-secure-random-32-byte-hex-string-for-prod"

# ── 2. Database (PostgreSQL) ──────────────────────────────────────────────────
# Default values for PostgreSQL container (used if self-hosting with Docker)
POSTGRES_USER=maintenance_user
POSTGRES_PASSWORD=maintenance_pass
POSTGRES_DB=oreon

# Main DB Connection string (override to point to Supabase, RDS, etc. if needed)
# Append '?sslmode=require' for remote managed database connections
DATABASE_URL=postgresql://maintenance_user:maintenance_pass@db:5432/oreon

# ── 3. AI & LLM Providers ────────────────────────────────────────────────────
# OREON defaults to Groq for low-latency Llama-3.3 narration.
LLM_PROVIDER="groq" 

# Populate with your API Keys (At least one must be provided for RAG operation)
GROQ_API_KEY="your-groq-api-key-here"
GROQ_MODEL="llama-3.3-70b-versatile"

# Google Gemini API key (optional fallback for conversational ask timeline)
GEMINI_API_KEY="your-gemini-api-key-here"

# Deepgram voice API key (required for automated speech STT/TTS)
DEEPGRAM_API_KEY="your-deepgram-api-key-here"


# ── 4. RAG, Vector DB, and Caching ───────────────────────────────────────────
# Keep this false to utilize fast hash embeddings. Enable only if rebuilding index.
USE_BGE_EMBEDDINGS=false
CHROMADB_PERSIST_DIR="/app/data/chroma"

# Qdrant Cloud Cluster settings (Required if scaling backend horizontally)
# QDRANT_URL="https://your-qdrant-cluster-url.aws.qdrant.io:6333"
# QDRANT_API_KEY="your-qdrant-api-key"

# Upstash Redis Cache URL (Required to cache embeddings & LLM answers in production)
# REDIS_URL="rediss://:your-redis-password@your-redis-cache.upstash.io:6379"

# ── 5. Data Directories ──────────────────────────────────────────────────────
DATA_DIR="/app/data"

# ── 6. Frontend Public API Url ────────────────────────────────────────────────
# Point this to the public URL where your FastAPI backend is exposed
VITE_API_URL="http://localhost:8000"
